// FitAgent Prisma Schema
// 参照: ../../docs/FitAgent_要件定義書.md §6.2

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  emailVerified   DateTime?
  password        String? // Credentials認証用ハッシュ（OAuthのみのユーザーはnull）
  name            String?
  image           String?
  goal            String?
  planType        String           @default("free")
  height          Float? // cm
  age             Int?
  gender          String? // "male" | "female"
  activityLevel   String? // "sedentary" | "light" | "moderate" | "active" | "very_active"
  createdAt       DateTime         @default(now())
  accounts        Account[]
  sessions        Session[]
  workoutSessions WorkoutSession[]
  aiAdvices       AiAdvice[]
  exercises       Exercise[]
  // bodyMetrics     BodyMetric[] // v2
  // mealLogs        MealLog[]    // v2
}

// --- NextAuth.js (Auth.js) Prisma Adapter 用 ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- トレーニング記録 ---

model Exercise {
  id          String       @id @default(cuid())
  name        String
  muscleGroup String // "胸" | "背中" | "脚" | "肩" | "腕" | "体幹"
  isCustom    Boolean      @default(false)
  userId      String?
  user        User?        @relation(fields: [userId], references: [id])
  workoutSets WorkoutSet[]
}

model WorkoutSession {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  date        DateTime
  notes       String?
  createdAt   DateTime     @default(now())
  workoutSets WorkoutSet[]
}

model WorkoutSet {
  id         String         @id @default(cuid())
  sessionId  String
  session    WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])
  weight     Float
  reps       Int
  setNumber  Int
  isPR       Boolean        @default(false)
}

// --- AI 提案 ---

model AiAdvice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  type      String // "menu_suggestion" | "analysis" | "stagnation_alert" | "goal_analysis"
  feedback  String? // "good" | "bad"
  createdAt DateTime @default(now())
}

